{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "GRAMPS_RESOURCES": "${workspaceFolder}",
        "GRAMPS_DATA_DIR": "${workspaceFolder}/data"
      }
    }
  ]
}
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Debug Gramps (WSL)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/Gramps.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "GRAMPS_RESOURCES": "${workspaceFolder}",
        "GRAMPS_DATA_DIR": "${workspaceFolder}/data"
        // "DISPLAY": ":0"        
      }
    }
  ]
}
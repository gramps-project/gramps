msgstr "Икеһе лә"

#: ../gramps/plugins/graph/gvfamilylines.py:165
msgid "Follow parents to determine \"family lines\""
msgstr "\"Ғаилә һыҙыҡтарын\" билдәләгәндә ата-әсәләр буйлап барыу"

#: ../gramps/plugins/graph/gvfamilylines.py:169
msgid ""
"Parents and their ancestors will be considered when determining \"family "
"lines\"."
msgstr ""
"\"Ғаилә һыҙыҡтарын\" билдәләгәндә ата-әсәләр һәм уларҙың ата-бабалары иҫәпкә "
"алынасаҡ."

#: ../gramps/plugins/graph/gvfamilylines.py:176
msgid "Follow children to determine \"family lines\""
msgstr "\"Ғаилә һыҙыҡтарын\" билдәләгәндә балалар буйлап барыу"

#: ../gramps/plugins/graph/gvfamilylines.py:179
msgid "Children will be considered when determining \"family lines\"."
msgstr "\"Ғаилә һыҙыҡтарын\" билдәләгәндә балалар иҫәпкә алынасаҡ."

#: ../gramps/plugins/graph/gvfamilylines.py:184
msgid "Try to remove extra people and families"
msgstr "Артыҡ кешеләрҙе һәм ғаиләләрҙе алып ташлап ҡарарға"

#: ../gramps/plugins/graph/gvfamilylines.py:188
msgid ""
"People and families not directly related to people of interest will be "
"removed when determining \"family lines\"."
msgstr ""
"\"Ғаилә һыҙыҡтарын\" билдәләгәндә ҡыҙыҡһындырған кешеләр менән тура бәйле "
"булмаған кешеләр һәм ғаиләләр алып ташланасаҡ."

#: ../gramps/plugins/graph/gvfamilylines.py:196
#: ../gramps/plugins/graph/gvhourglass.py:482
#: ../gramps/plugins/graph/gvrelgraph.py:924
